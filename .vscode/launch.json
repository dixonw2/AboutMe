{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Client",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "args": ["start"],
      "cwd": "${workspaceFolder}/client",
      "console": "integratedTerminal",
      "timeout": 30000
    },
    {
      "name": "API",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload"],
      "cwd": "${workspaceFolder}/api",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Both",
      "configurations": ["Client", "API"]
    }
  ]
}
